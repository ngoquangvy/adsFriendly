{
  "manifest_version": 3,
  "name": "AdsFriendly",
  "version": "3.0.0",
  "description": "Chặn quảng cáo thông minh dựa trên AI đa lớp (Fusion Brain), Pop-under và bảo vệ hành vi người dùng.",
  "permissions": [
    "declarativeNetRequest",
    "webNavigation",
    "tabs",
    "storage",
    "scripting",
    "webRequest"
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "match_about_blank": true,
      "js": [
        "core/api_gateway.js",
        "core/BrainBridge.js",
        "core/modules/dom_vision.js",
        "core/modules/heuristics.js",
        "core/modules/trusted_clicker.js",
        "core/modules/danger_zone.js",
        "core/modules/playback_control.js",
        "core/modules/skip_engine.js",
        "core/modules/session_manager.js",
        "core/modules/telemetry_sentinel.js",
        "core/adapters/base_adapter.js",
        "core/adapters/hls_adapter.js",
        "core/adapters/jw_adapter.js",
        "core/adapters/youtube_adapter.js",
        "core/adapters/dash_adapter.js",
        "core/adapters/custom_adapter.js",
        "core/ad_detection.js",
        "core/strategy_engine.js",
        "telemetry/evaluator.js",
        "content.js",
        "picker.js",
        "video_surgeon.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": false,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "ui/blocked.html",
        "core/modules/proxy_shield.js",
        "core/modules/xhr_radar.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
